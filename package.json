{
  "name": "chat-pedagogique-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:e2e": "playwright test --reporter=line",
    "test:e2e:headed": "playwright test --headed --reporter=line",
    "audit": "lighthouse http://localhost:5173/chat-llm/ --output json --output html --output-path ./lighthouse-report --chrome-flags=\"--headless\" --only-categories=accessibility,best-practices,seo,performance",
    "audit:ci": "node scripts/lighthouse-ci.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lighthouse": "^13.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
